# SealProof -- SealProof Notary Environment Variables
# Copy this to .env.local and fill in real values

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_XXXXXXXX
CLERK_SECRET_KEY=sk_live_XXXXXXXX
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# App
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=SealProof Notary

# Backend Services (proxied through Next.js API routes)
SESSION_ORCHESTRATOR_URL=http://localhost:4003
KYC_SVC_URL=http://localhost:4004
LIVEKIT_BRIDGE_URL=http://localhost:4005
ESIGN_BRIDGE_URL=http://localhost:4006
JOURNAL_SVC_URL=http://localhost:4007
RECORDING_SVC_URL=http://localhost:4008
SEAL_SVC_URL=http://localhost:4009
PAYMENT_SVC_URL=http://localhost:4010
NOTIFICATION_SVC_URL=http://localhost:4011
AUDIT_EXPORT_URL=http://localhost:4012
API_GATEWAY_URL=http://localhost:4013
WEBHOOK_SVC_URL=http://localhost:4014
TENANT_SVC_URL=http://localhost:4015
STATE_COMPLIANCE_URL=http://localhost:4016
KBA_SVC_URL=http://localhost:4017
NOTARY_COMMISSION_URL=http://localhost:4001
NOTARY_ROSTER_URL=http://localhost:4002
