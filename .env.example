# SealProof Environment Configuration
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql://sealproof_app:changeme@localhost:5432/sealproof
DATABASE_URL_READONLY=postgresql://sealproof_readonly:changeme@localhost:5433/sealproof

# Redis
REDIS_URL=redis://localhost:6379
REDIS_CLUSTER_URLS=redis://localhost:6379,redis://localhost:6380,redis://localhost:6381

# Auth (Clerk)
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# Services — Stage 1
COMMISSION_SVC_PORT=4001
ROSTER_SVC_PORT=4002
ORCHESTRATOR_SVC_PORT=4003

# Services — Stage 2
KYC_SVC_PORT=4004
LIVEKIT_SVC_PORT=4005
ESIGN_SVC_PORT=4006

# Persona KYC
PERSONA_API_KEY=persona_xxxxx
PERSONA_TEMPLATE_ID=itmpl_xxxxx
PERSONA_BASE_URL=https://withpersona.com/api/v1
PERSONA_WEBHOOK_SECRET=whs_xxxxx

# LiveKit
LIVEKIT_WS_URL=wss://livekit.trgtechlink.com
LIVEKIT_API_KEY=APIxxxxx
LIVEKIT_API_SECRET=xxxxx

# TRG E-Sign
TRG_ESIGN_BASE_URL=https://esign.trgtechlink.com/api/v1
TRG_ESIGN_API_KEY=xxxxx

# AWS
AWS_ACCESS_KEY_ID=AKIA_xxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_REGION=us-east-1
AWS_RECORDING_BUCKET=sealproof-recordings
AWS_DOCUMENT_BUCKET=sealproof-documents

# Base URL (for webhook callbacks)
BASE_URL=http://localhost:4006

# Logging
LOG_LEVEL=info
NODE_ENV=development

# White-Label Tenant Service
TENANT_SVC_PORT=4015
STATE_COMPLIANCE_SVC_PORT=4016
KBA_SVC_PORT=4017

# IDology (KBA Provider)
IDOLOGY_BASE_URL=https://web.idologylive.com/api
IDOLOGY_USERNAME=
IDOLOGY_PASSWORD=

# Application Domain
APP_DOMAIN=sealproof.ai
APP_URL=https://sealproof.ai
NOTARY_APP_URL=https://notary.sealproof.ai
ADMIN_URL=https://admin.sealproof.ai
API_URL=https://api.sealproof.ai
